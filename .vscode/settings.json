{
    "editor.formatOnSave": true,
    "css.format.braceStyle": "expand",
    "less.format.braceStyle": "expand",
    "scss.format.braceStyle": "expand",
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "[typescript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "js/ts.format.insertSpaceAfterOpeningAndBeforeClosingTemplateStringBraces": false,
    "js/ts.format.placeOpenBraceOnNewLineForFunctions": true,
    "js/ts.format.placeOpenBraceOnNewLineForControlBlocks": true
}